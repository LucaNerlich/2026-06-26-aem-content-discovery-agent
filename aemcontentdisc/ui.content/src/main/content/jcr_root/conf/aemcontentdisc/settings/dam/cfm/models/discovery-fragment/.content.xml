<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Template"
    allowedPaths="[/content/dam/aemcontentdisc(/.*)?]"
    ranking="{Long}100">
    <jcr:content
        cq:scaffolding="/conf/aemcontentdisc/settings/dam/cfm/models/discovery-fragment/jcr:content/model"
        cq:templateType="/libs/settings/dam/cfm/model-types/fragment"
        jcr:description="Content Fragment model for the AEM Content Discovery Agent corpus."
        jcr:primaryType="cq:PageContent"
        jcr:title="Discovery Fragment"
        sling:resourceSuperType="dam/cfm/models/console/components/data/entity"
        sling:resourceType="dam/cfm/models/console/components/data/entity/default"
        status="enabled">
        <metadata jcr:primaryType="nt:unstructured"/>
        <model
            cq:targetPath="/content/dam/aemcontentdisc"
            jcr:primaryType="cq:PageContent"
            sling:resourceType="wcm/scaffolding/components/scaffolding"
            dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
            maxGeneratedOrder="20">
            <cq:dialog
                jcr:primaryType="nt:unstructured"
                sling:resourceType="cq/gui/components/authoring/dialog">
                <content
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                    <items
                        jcr:primaryType="nt:unstructured"
                        maxGeneratedOrder="28">
                        <id
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldDescription="Stable unique slug, e.g. frag_001. Used as JCR node name."
                            fieldLabel="ID"
                            listOrder="1"
                            maxlength="255"
                            metaType="text-single"
                            name="id"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </id>
                        <title
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldDescription="Human-readable page/component title."
                            fieldLabel="Title"
                            listOrder="2"
                            maxlength="255"
                            metaType="text-single"
                            name="title"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </title>
                        <category
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                            emptyOption="{Boolean}false"
                            fieldDescription="Editorial category. Extend by adding options here and in the agent's schema."
                            fieldLabel="Category"
                            listOrder="3"
                            metaType="enumeration"
                            name="category"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <optionsmultifield jcr:primaryType="nt:unstructured">
                                <item0
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Product Story"
                                    fieldValue="product-story"/>
                                <item1
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Care Guide"
                                    fieldValue="care-guide"/>
                                <item2
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Seasonal Campaign"
                                    fieldValue="seasonal-campaign"/>
                            </optionsmultifield>
                            <datasource
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="dam/cfm/admin/components/datasources/optionrendererenumeration"
                                variant="default"/>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </category>
                        <targetAudience
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="Target Audience"
                            default-mime-type="text/plain"
                            fieldDescription="Short demographic description, e.g. 'Eco-conscious women aged 25-40, UK market.'"
                            fieldLabel="Target Audience"
                            listOrder="4"
                            metaType="text-multi"
                            name="targetAudience"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string"/>
                        <brandGuidelinesApplied
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                            fieldDescription="Multi-value, e.g. sustainability-voice, premium-tone, inclusive-language, technical-precision."
                            fieldLabel="Brand Guidelines Applied"
                            listOrder="5"
                            metaType="text-single"
                            name="brandGuidelinesApplied"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string[]">
                            <field
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                name="./brandGuidelinesApplied"/>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </brandGuidelinesApplied>
                        <locale
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                            emptyOption="{Boolean}false"
                            fieldDescription="Corpus locale. Hard pre-filter on retrieval in the agent."
                            fieldLabel="Locale"
                            listOrder="6"
                            metaType="enumeration"
                            name="locale"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <optionsmultifield jcr:primaryType="nt:unstructured">
                                <item0
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="English (UK)"
                                    fieldValue="en-gb"/>
                                <item1
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="French (France)"
                                    fieldValue="fr-fr"/>
                                <item2
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="German (Germany)"
                                    fieldValue="de-de"/>
                            </optionsmultifield>
                            <datasource
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="dam/cfm/admin/components/datasources/optionrendererenumeration"
                                variant="default"/>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </locale>
                        <lastModified
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                            displayedFormat="YYYY-MM-DD HH:mm"
                            emptyText="YYYY-MM-DD HH:mm"
                            fieldDescription="Full ISO 8601 datetime. Agent uses it for freshness scoring."
                            fieldLabel="Last Modified"
                            listOrder="7"
                            metaType="date"
                            name="lastModified"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            type="datetime"
                            valueFormat="YYYY-MM-DD[T]HH:mm:ss.000Z"
                            valueType="calendar/datetime">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                typeHint="Date"/>
                        </lastModified>
                        <content
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="Content"
                            default-mime-type="text/html"
                            fieldDescription="Body text, at least 100 words (target 150-250 words). Locale-appropriate."
                            fieldLabel="Content"
                            listOrder="8"
                            metaType="text-multi"
                            name="content"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string/multiline"/>
                    </items>
                </content>
            </cq:dialog>
        </model>
    </jcr:content>
</jcr:root>
