{
  "name": "aem-content-discovery-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "shared",
    "content-seeder",
    "discovery-agent"
  ],
  "scripts": {
    "seed": "npm run -w content-seeder seed --",
    "embed": "npm run -w content-seeder embed --",
    "agent": "npm run -w discovery-agent start --",
    "eval": "node eval/run.js",
    "full-run": "node scripts/full-run.js",
    "test": "node --test --test-reporter spec 'shared/test/**/*.test.js' 'content-seeder/test/**/*.test.js' 'discovery-agent/test/**/*.test.js' 'scripts/test/**/*.test.js'"
  },
  "dependencies": {
    "@aemdisc/shared": "workspace:*"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
